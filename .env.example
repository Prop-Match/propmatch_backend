# Trusted public origin used for short-lived admin KYC document URLs.
BACKEND_PUBLIC_URL=http://localhost:3001

# Internal FastAPI legal RAG service. Use the same strong service key in the
# legal-support FastAPI environment; this is not the user's JWT secret.
LEGAL_SUPPORT_API_URL=http://localhost:8001
LEGAL_SUPPORT_INTERNAL_API_KEY=replace-with-a-long-random-internal-service-key
LEGAL_SUPPORT_TIMEOUT_MS=120000
