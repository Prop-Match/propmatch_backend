// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TENANT
  LANDLORD
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMISSION_REQUIRED
}

enum PropertyType {
  APARTMENT
  VILLA
  STUDIO
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ConnectionStatus {
  INTERESTED
  CONNECTED
  REJECTED
}

enum PaymentType {
  NEW_LISTING
  BOOST_LISTING
  REFILL_MATCHES
  OFFER_PACK
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentProvider {
  PAYMOB
}

enum NotificationType {
  EKYC_APPROVED
  PROPERTY_APPROVED
  NEW_MATCH
  PAYMENT_SUCCESS
  NEW_REVIEW_SUBMITTED
  REVIEW_APPROVED
  NEW_TENANT_REQUEST
  NEW_OFFER_RECEIVED
  NEW_MESSAGE
}

enum TenantRequestStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
  CLOSED
}

enum OwnerOfferStatus {
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

enum PartnerServiceType {
  MOVING
  INSURANCE
}

/**
 * Lifecycle: NEW → ASSIGNED → IN_PROGRESS → WAITING → CLOSED (frontend TicketStatusSchema).
 */
enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING
  CLOSED
}

/**
 * Who authored a support message (frontend SupportAuthorSchema).
 */
enum SupportAuthor {
  AI
  USER
  ADMIN
}

enum PartnerLeadStatus {
  PENDING
  SENT
  CONVERTED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name")
  email        String    @unique
  phoneNumber  String    @map("phone_number")
  passwordHash String    @map("password_hash")
  role         UserRole  @default(TENANT)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Profiles & Settings
  identityVerification IdentityVerification?
  userQuota            UserQuota?
  tenantRequests       TenantRequest[]       @relation("TenantRequests")
  favorites            Favorite[]

  // Property Ownership & Actions
  properties Property[] @relation("PropertyOwner")

  // Offers & Partner Strategic Lead Routing
  ownerOffers  OwnerOffer[]
  partnerLeads PartnerLead[]

  // Reviews
  propertyReviews PropertyReview[] @relation("ReviewWriter")

  // Matchmaker Connections
  ownerMatchConnections  MatchConnection[] @relation("OwnerMatchConnections")
  tenantMatchConnections MatchConnection[] @relation("TenantMatchConnections")

  // Administration Approvals
  approvedVerifications IdentityVerification[] @relation("ApprovedVerifications")
  approvedProperties    Property[]             @relation("ApprovedProperties")
  approvedReviews       PropertyReview[]       @relation("ApprovedReviews")
  approvedRequests      TenantRequest[]        @relation("ApprovedRequests")

  // Transactions & Billing
  paymentTransactions PaymentTransaction[]
  leaseContracts      LeaseContract[]
  notifications       Notification[]
  sentMessages        Message[]

  // Admin activity (team page)
  loginAttempts   LoginAttempt[]
  auditLogEntries AdminAuditLogEntry[]

  // Customer support tickets (AI handoff → human admin)
  supportTickets         SupportTicket[]  @relation("TicketOwner")
  assignedSupportTickets SupportTicket[]  @relation("TicketAssignee")
  supportMessages        SupportMessage[] @relation("SupportMessageAuthor")

  @@map("user")
}

model IdentityVerification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  // Transitional private field retained for compatibility.
  // Never expose through ordinary APIs or logs.
  nationalId String? @map("national_id")

  nationalIdFrontUrl String @map("national_id_front_url")
  nationalIdBackUrl  String @map("national_id_back_url")
  selfieUrl          String @map("selfie_url")

  status VerificationStatus @default(PENDING)

  // Admin Approval
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewer        User?     @relation("ApprovedVerifications", fields: [reviewedBy], references: [id])
  rejectionReason String?   @map("rejection_reason")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("identity_verification")
}

model UserQuota {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  user              User     @relation(fields: [userId], references: [id])
  freeListingsLeft  Int      @default(1) @map("free_listings_left")
  optimizerUsesLeft Int      @default(2) @map("optimizer_uses_left")
  freeOffersLeft    Int      @default(3) @map("free_offers_left")
  lastResetDate     DateTime @default(now()) @map("last_reset_date")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_quota")
}

model Property {
  id                     String         @id @default(uuid()) @db.Uuid
  ownerId                String         @map("owner_id") @db.Uuid
  owner                  User           @relation("PropertyOwner", fields: [ownerId], references: [id])
  title                  String
  description            String
  country                Country        @relation(fields: [countryId], references: [id], onDelete: Restrict)
  governorate            Governorate    @relation(fields: [governorateId], references: [id], onDelete: Restrict)
  city                   City           @relation(fields: [cityId], references: [id], onDelete: Restrict)
  district               String
  manualAddress          String         @map("manual_address")
  propertyType           PropertyType   @map("property_type")
  propertyAroundServices String?        @map("property_around_services") @db.Text
  rentAmount             Float          @map("rent_amount")
  areaM2                 Float          @map("area_m2")
  bedrooms               Int
  bathrooms              Int
  isFurnished            Boolean        @map("is_furnished")
  hasElevator            Boolean        @map("has_elevator")
  hasParking             Boolean        @map("has_parking")
  contactRevealed        Boolean        @default(false) @map("contact_revealed")
  status                 PropertyStatus @default(PENDING)
  isBoosted              Boolean        @default(false) @map("is_boosted")

  // Admin Approval
  approvedBy     String?   @map("approved_by") @db.Uuid
  approvedByUser User?     @relation("ApprovedProperties", fields: [approvedBy], references: [id])
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  propertyImages   PropertyImage[]
  propertyReviews  PropertyReview[]
  favorites        Favorite[]
  matchConnections MatchConnection[]
  ownerOffers      OwnerOffer[]
  governorateId    Int
  cityId           Int
  countryId        Int

  @@map("property")
}

model PropertyImage {
  id           String   @id @default(uuid()) @db.Uuid
  propertyId   String   @map("property_id") @db.Uuid
  property     Property @relation(fields: [propertyId], references: [id])
  imageUrl     String   @map("image_url")
  displayOrder Int      @map("display_order")
  isCover      Boolean  @default(false) @map("is_cover")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("property_image")
}

model PropertyReview {
  id         String             @id @default(uuid()) @db.Uuid
  reviewerId String             @map("reviewer_id") @db.Uuid
  reviewer   User               @relation("ReviewWriter", fields: [reviewerId], references: [id])
  propertyId String             @map("property_id") @db.Uuid
  property   Property           @relation(fields: [propertyId], references: [id])
  rating     Int
  comment    String?            @db.Text
  status     VerificationStatus @default(PENDING)

  // Admin Approval
  reviewedBy String?  @map("reviewed_by") @db.Uuid
  reviewerBy User?    @relation("ApprovedReviews", fields: [reviewedBy], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("property_review")
}

model TenantRequest {
  id                    String              @id @default(uuid()) @db.Uuid
  tenantId              String              @map("tenant_id") @db.Uuid
  tenant                User                @relation("TenantRequests", fields: [tenantId], references: [id])
  minBudget             Float               @map("min_budget")
  maxBudget             Float               @map("max_budget")
  preferredLocations    String              @map("preferred_locations")
  propertyType          PropertyType        @map("property_type")
  requiredBedrooms      Int                 @map("required_bedrooms")
  needsFurnished        Boolean             @map("needs_furnished")
  flexibilityScore      Int                 @map("flexibility_score")
  lifestyleRequirements String              @map("lifestyle_requirements") @db.Text
  status                TenantRequestStatus @default(PENDING)
  approvedBy            String?             @map("approved_by") @db.Uuid
  approvedByUser        User?               @relation("ApprovedRequests", fields: [approvedBy], references: [id])
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  ownerOffers           OwnerOffer[]

  @@map("tenant_request")
}

model OwnerOffer {
  id              String           @id @default(uuid()) @db.Uuid
  ownerId         String           @map("owner_id") @db.Uuid
  owner           User             @relation(fields: [ownerId], references: [id])
  tenantRequestId String           @map("tenant_request_id") @db.Uuid
  tenantRequest   TenantRequest    @relation(fields: [tenantRequestId], references: [id])
  propertyId      String?          @map("property_id") @db.Uuid
  property        Property?        @relation(fields: [propertyId], references: [id])
  pitchMessage    String           @map("pitch_message") @db.Text
  proposedPrice   Float            @map("proposed_price")
  status          OwnerOfferStatus @default(SENT)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("owner_offer")
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     User     @relation(fields: [tenantId], references: [id])
  propertyId String   @map("property_id") @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([tenantId, propertyId])
  @@map("favorite")
}

model MatchConnection {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  tenant     User             @relation("TenantMatchConnections", fields: [tenantId], references: [id])
  propertyId String           @map("property_id") @db.Uuid
  property   Property         @relation(fields: [propertyId], references: [id])
  ownerId    String           @map("owner_id") @db.Uuid
  owner      User             @relation("OwnerMatchConnections", fields: [ownerId], references: [id])
  matchScore Float            @map("match_score")
  status     ConnectionStatus @default(INTERESTED)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  messages   Message[]

  @@map("match_connection")
}

model Message {
  id                String   @id @default(uuid()) @db.Uuid
  matchConnectionId String   @map("match_connection_id") @db.Uuid
  senderId          String   @map("sender_id") @db.Uuid
  body              String   @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  matchConnection MatchConnection @relation(fields: [matchConnectionId], references: [id], onDelete: Cascade)
  sender          User            @relation(fields: [senderId], references: [id], onDelete: Restrict)

  @@index([matchConnectionId, createdAt])
  @@index([senderId])
  @@map("message")
}

model PaymentTransaction {
  id                    String          @id @default(uuid()) @db.Uuid
  userId                String          @map("user_id") @db.Uuid
  user                  User            @relation(fields: [userId], references: [id])
  provider              PaymentProvider @default(PAYMOB)
  providerOrderId       String          @unique @map("provider_order_id")
  providerTransactionId String?         @map("provider_transaction_id")
  amount                Float
  currency              String          @default("EGP")
  paymentType           PaymentType     @map("payment_type")
  status                PaymentStatus   @default(PENDING)
  paidAt                DateTime?       @map("paid_at")
  createdAt             DateTime        @default(now()) @map("created_at")

  @@map("payment_transaction")
}

model LeaseContract {
  id                String   @id @default(uuid()) @db.Uuid
  generatedByUserId String   @map("generated_by_user_id") @db.Uuid
  generatedBy       User     @relation(fields: [generatedByUserId], references: [id])
  ownerName         String   @map("owner_name")
  ownerNationalId   String   @map("owner_national_id")
  tenantName        String   @map("tenant_name")
  tenantNationalId  String   @map("tenant_national_id")
  propertyAddress   String   @map("property_address")
  customClauses     String?  @map("custom_clauses") @db.Text
  pdfUrl            String?  @map("pdf_url")
  startDate         DateTime @map("start_date")
  endDate           DateTime @map("end_date")
  rentAmount        Float    @map("rent_amount")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("lease_contract")
}

model PartnerLead {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  tenant      User               @relation(fields: [tenantId], references: [id])
  serviceType PartnerServiceType @map("service_type")
  partnerName String             @map("partner_name")
  status      PartnerLeadStatus  @default(PENDING)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("partner_lead")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notification")
}

/**
 * Admin-panel login attempts (team activity page). Only ADMIN-role accounts are recorded.
 */
model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  ip        String
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("login_attempt")
}

/**
 * Append-only record of sensitive admin moderation actions (team activity page).
 */
model AdminAuditLogEntry {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String   @map("actor_id") @db.Uuid
  actor     User     @relation(fields: [actorId], references: [id])
  action    String
  subjectId String   @map("subject_id") @db.Uuid
  at        DateTime @default(now())

  @@index([at])
  @@map("admin_audit_log_entry")
}

model Country {
  id           Int           @id @default(autoincrement())
  nameAr       String        @map("name_ar")
  nameEn       String        @map("name_en")
  code         String        @unique
  image        String
  status       Boolean       @default(true)
  governorates Governorate[]
  properties   Property[]

  @@map("country")
}

model Governorate {
  id         Int        @id @default(autoincrement())
  countryId  Int        @map("country_id")
  country    Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  nameAr     String     @map("name_ar")
  nameEn     String     @map("name_en")
  status     Boolean    @default(true)
  cities     City[]
  properties Property[]

  @@map("governorate")
}

model City {
  id            Int         @id @default(autoincrement())
  governorateId Int         @map("governorate_id")
  governorate   Governorate @relation(fields: [governorateId], references: [id], onDelete: Cascade)
  nameAr        String      @map("name_ar")
  nameEn        String      @map("name_en")
  status        Boolean     @default(true)
  properties    Property[]
  districts     District[]

  @@map("city")
}

model District {
  id     Int     @id @default(autoincrement())
  cityId Int     @map("city_id")
  city   City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
  nameAr String  @map("name_ar")
  nameEn String  @map("name_en")
  status Boolean @default(false)

  @@map("district")
}

/**
 * Human-support ticket, created by the external legal-support AI service via
 * `transfer_to_human_support(user_id, chat_summary)` when it declines an
 * off-topic question or the user explicitly asks for a human. Has no ERD
 * entity / PRO ticket — modeled from the frontend's existing contract
 * (src/lib/api/contracts/support.ts) since that's the only agreed shape.
 */
model SupportTicket {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  user            User             @relation("TicketOwner", fields: [userId], references: [id])
  subject         String
  status          TicketStatus     @default(NEW)
  assignedAdminId String?          @map("assigned_admin_id") @db.Uuid
  assignedAdmin   User?            @relation("TicketAssignee", fields: [assignedAdminId], references: [id])
  createdAt       DateTime         @default(now()) @map("created_at")
  lastMessageAt   DateTime         @map("last_message_at")
  messages        SupportMessage[]

  @@index([status, lastMessageAt])
  @@map("support_ticket")
}

model SupportMessage {
  id         String        @id @default(uuid()) @db.Uuid
  ticketId   String        @map("ticket_id") @db.Uuid
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     SupportAuthor
  /**
   * Set only when author = ADMIN — which admin wrote this reply.
   */
  authorId   String?       @map("author_id") @db.Uuid
  authorUser User?         @relation("SupportMessageAuthor", fields: [authorId], references: [id])
  content    String        @db.Text
  /**
   * Internal admin notes are never sent to the customer (mocks/router.ts parity).
   */
  internal   Boolean       @default(false)
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_message")
}
