// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  REGULAR
  ADMIN
  SUPERADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PropertyType {
  APARTMENT
  VILLA
  STUDIO
  DUPLEX
  ROOM
  SHOP
  OFFICE
}

enum PropertyStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ConnectionStatus {
  INTERESTED
  CONNECTED
  REJECTED
}

enum PaymentType {
  NEW_LISTING
  BOOST_LISTING
  REFILL_MATCHES
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  EKYC_APPROVED
  PROPERTY_APPROVED
  NEW_MATCH
  PAYMENT_SUCCESS
  NEW_REVIEW_SUBMITTED
  REVIEW_APPROVED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @map("full_name")
  email        String    @unique
  phoneNumber  String    @map("phone_number")
  passwordHash String    @map("password_hash")
  role         UserRole  @default(REGULAR)
  isActive     Boolean   @default(true) @map("is_active")
  isAdmin      Boolean   @default(false) @map("is_admin")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Profiles & Settings
  identityVerification IdentityVerification?
  userQuota            UserQuota?
  tenantPreferences    TenantPreference[]
  favorites            Favorite[]

  // Property Ownership & Actions
  properties Property[] @relation("PropertyOwner")

  // Reviews
  propertyReviews PropertyReview[] @relation("ReviewWriter")

  // Matchmaker Connections
  ownerMatchConnections  MatchConnection[] @relation("OwnerMatchConnections")
  tenantMatchConnections MatchConnection[] @relation("TenantMatchConnections")

  // Administration Approvals
  approvedVerifications IdentityVerification[] @relation("ApprovedVerifications")
  approvedProperties    Property[]             @relation("ApprovedProperties")
  approvedReviews       PropertyReview[]       @relation("ApprovedReviews")

  // Transactions & Billing
  paymentTransactions PaymentTransaction[]
  leaseContracts      LeaseContract[]
  notifications       Notification[]

  @@map("user")
}

model IdentityVerification {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  user               User               @relation(fields: [userId], references: [id])
  nationalId         String             @map("national_id")
  nationalIdFrontUrl String             @map("national_id_front_url")
  nationalIdBackUrl  String             @map("national_id_back_url")
  selfieUrl          String             @map("selfie_url")
  status             VerificationStatus @default(PENDING)

  // Admin Approval
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewer        User?     @relation("ApprovedVerifications", fields: [reviewedBy], references: [id])
  rejectionReason String?   @map("rejection_reason")
  submittedAt     DateTime  @default(now()) @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")

  @@map("identity_verification")
}

model UserQuota {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  user                  User     @relation(fields: [userId], references: [id])
  freeListingsLeft      Int      @default(1) @map("free_listings_left")
  freeMatchSearchesLeft Int      @default(3) @map("free_match_searches_left")
  optimizerUsesLeft     Int      @default(2) @map("optimizer_uses_left")
  lastResetDate         DateTime @default(now()) @map("last_reset_date")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("user_quota")
}

model Property {
  id                     String         @id @default(uuid()) @db.Uuid
  ownerId                String         @map("owner_id") @db.Uuid
  owner                  User           @relation("PropertyOwner", fields: [ownerId], references: [id])
  title                  String
  description            String
  governorate            String
  city                   String
  district               String
  manualAddress          String         @map("manual_address")
  propertyType           PropertyType   @map("property_type")
  propertyAroundServices String?        @map("property_around_services") @db.Text
  rentAmount             Float          @map("rent_amount")
  areaM2                 Float          @map("area_m2")
  bedrooms               Int
  bathrooms              Int
  isFurnished            Boolean        @map("is_furnished")
  hasElevator            Boolean        @map("has_elevator")
  hasParking             Boolean        @map("has_parking")
  contactRevealed        Boolean        @default(false) @map("contact_revealed")
  status                 PropertyStatus @default(PENDING)
  isBoosted              Boolean        @default(false) @map("is_boosted")

  // Admin Approval
  approvedBy     String?   @map("approved_by") @db.Uuid
  approvedByUser User?     @relation("ApprovedProperties", fields: [approvedBy], references: [id])
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  propertyImages   PropertyImage[]
  propertyReviews  PropertyReview[]
  favorites        Favorite[]
  matchConnections MatchConnection[]

  @@map("property")
}

model PropertyImage {
  id           String   @id @default(uuid()) @db.Uuid
  propertyId   String   @map("property_id") @db.Uuid
  property     Property @relation(fields: [propertyId], references: [id])
  imageUrl     String   @map("image_url")
  displayOrder Int      @map("display_order")
  isCover      Boolean  @default(false) @map("is_cover")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("property_image")
}

model PropertyReview {
  id         String             @id @default(uuid()) @db.Uuid
  reviewerId String             @map("reviewer_id") @db.Uuid
  reviewer   User               @relation("ReviewWriter", fields: [reviewerId], references: [id])
  propertyId String             @map("property_id") @db.Uuid
  property   Property           @relation(fields: [propertyId], references: [id])
  rating     Int
  comment    String?            @db.Text
  status     VerificationStatus @default(PENDING)

  // Admin Approval
  reviewedBy String?  @map("reviewed_by") @db.Uuid
  reviewerBy User?    @relation("ApprovedReviews", fields: [reviewedBy], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("property_review")
}

model TenantPreference {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  tenant                 User     @relation(fields: [tenantId], references: [id])
  maxBudget              Float    @map("max_budget")
  requiredBedrooms       Int      @map("required_bedrooms")
  needsFurnished         Boolean  @map("needs_furnished")
  preferredNeighborhoods String   @map("preferred_neighborhoods") @db.Text
  lifestyleRequirements  String?  @map("lifestyle_requirements") @db.Text
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("tenant_preference")
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  tenant     User     @relation(fields: [tenantId], references: [id])
  propertyId String   @map("property_id") @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([tenantId, propertyId])
  @@map("favorite")
}

model MatchConnection {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  tenant     User             @relation("TenantMatchConnections", fields: [tenantId], references: [id])
  propertyId String           @map("property_id") @db.Uuid
  property   Property         @relation(fields: [propertyId], references: [id])
  ownerId    String           @map("owner_id") @db.Uuid
  owner      User             @relation("OwnerMatchConnections", fields: [ownerId], references: [id])
  matchScore Float            @map("match_score")
  status     ConnectionStatus @default(INTERESTED)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  @@map("match_connection")
}

model PaymentTransaction {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  user                User          @relation(fields: [userId], references: [id])
  paymobOrderId       String        @unique @map("paymob_order_id")
  paymobTransactionId String?       @map("paymob_transaction_id")
  amount              Float
  currency            String        @default("EGP")
  paymentType         PaymentType   @map("payment_type")
  status              PaymentStatus @default(PENDING)
  paidAt              DateTime?     @map("paid_at")
  createdAt           DateTime      @default(now()) @map("created_at")

  @@map("payment_transaction")
}

model LeaseContract {
  id                String   @id @default(uuid()) @db.Uuid
  generatedByUserId String   @map("generated_by_user_id") @db.Uuid
  generatedBy       User     @relation(fields: [generatedByUserId], references: [id])
  ownerName         String   @map("owner_name")
  ownerNationalId   String   @map("owner_national_id")
  tenantName        String   @map("tenant_name")
  tenantNationalId  String   @map("tenant_national_id")
  propertyAddress   String   @map("property_address")
  customClauses     String?  @map("custom_clauses") @db.Text
  pdfUrl            String?  @map("pdf_url")
  startDate         DateTime @map("start_date")
  endDate           DateTime @map("end_date")
  rentAmount        Float    @map("rent_amount")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("lease_contract")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notification")
}
