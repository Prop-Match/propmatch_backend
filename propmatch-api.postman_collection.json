            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.accessToken) {",
                  "    pm.collectionVariables.set(\"jwt_token\", response.accessToken);",
                  "    pm.collectionVariables.set(\"refresh_token\", response.refreshToken);",
