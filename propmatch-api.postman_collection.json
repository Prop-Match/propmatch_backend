              "raw": "{\n    \"fullName\": \"محمد المستأجر\",\n    \"email\": \"tenant.test@example.com\",\n    \"password\": \"P@ssword123\",\n    \"phoneNumber\": \"01092219864\",\n    \"role\": \"TENANT\"\n}",
